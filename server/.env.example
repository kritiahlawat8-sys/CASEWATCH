# Server configuration
PORT=5001
NODE_ENV=development

# Google OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback

# Database configuration
# Option 1: Use a connection URL (recommended)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/casewatch_db

# Option 2: Individual connection options (fallback)
# DB_USER=postgres
# DB_HOST=localhost
# DB_DATABASE=casewatch_db
# DB_PASSWORD=postgres
# DB_PORT=5432

# Authentication secret
JWT_SECRET=replace_this_with_a_long_random_secure_secret_string
